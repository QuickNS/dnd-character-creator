    ],
    "subclass": [
      {
        "description": "You gain proficiency with one type of Artisan's Tools of your choice, and you gain proficiency in one skill of your choice from the skills available to Fighters at level 1.",
        "level": 3,
        "name": "Student of War",
        "source": "Battle Master"
      },
      {
        "description": "You learn maneuvers that are fueled by special dice called Superiority Dice. You learn three maneuvers of your choice. You have four Superiority Dice (d8s). A Superiority Die is expended when you use it. You regain all expended Superiority Dice when you finish a Short or Long Rest. You gain additional Superiority Dice at levels 7 and 15. If a maneuver requires a saving throw, the DC equals 8 + your Strength or Dexterity modifier (your choice) + Proficiency Bonus.",
        "level": 3,
        "name": "Combat Superiority",
        "source": "Battle Master"
      }
    ]
