        "source": "Fighter"
      },
      {
        "description": "When you fail an ability check, you can expend a use of your Second Wind to push yourself toward success. Rather than regaining Hit Points, you roll 1d10 and add the number rolled to the ability check, potentially turning it into a success. If the check still fails, this use of Second Wind isn't expended.",
        "level": 2,
        "name": "Tactical Mind",
        "source": "Fighter"
      },
      {
        "description": "Your training with weapons allows you to use the mastery properties of three kinds of Simple or Martial weapons of your choice. Whenever you finish a Long Rest, you can switch one mastery.",
        "level": 1,
        "name": "Weapon Mastery",
        "source": "Fighter"
      }
    ],
    "feats": [
      {
        "description": "You have inexplicable luck that seems to kick in at just the right moment.\n\n**Luck Points.** You have a number of Luck Points equal to your Proficiency Bonus and can spend the points on the benefits below. You regain your expended Luck Points when you finish a Long Rest.\n\n**Advantage.** When you roll a d20 for a D20 Test, you can spend 1 Luck Point to give yourself Advantage on the roll.\n\n**Disadvantage.** When a creature rolls a d20 for an attack roll against you, you can spend 1 Luck Point to impose Disadvantage on that roll.",
        "name": "Lucky",
        "source": "Versatile: Lucky"
      },
      {
        "description": "You've trained to deal particularly damaging strikes. Once per turn when you hit a target with a weapon, you can roll the weapon's damage dice twice and use either roll against the target.",
        "name": "Savage Attacker",
        "source": "Soldier"
      }
    ],
    "lineage": [],
    "species": [
      {
        "description": "You gain Heroic Inspiration whenever you finish a Long Rest.",
        "name": "Resourceful",
        "source": "Human"
      },
      {
        "description": "You gain an Origin feat of your choice. Skilled is recommended.",
        "name": "Versatile: Lucky",
        "source": "Human"
      },
      {
        "description": "You gain proficiency in one skill of your choice.",
        "name": "Skillful: Investigation",
