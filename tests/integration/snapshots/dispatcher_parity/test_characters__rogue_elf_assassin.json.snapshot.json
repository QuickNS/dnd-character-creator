  "features": {
    "background": [],
    "class": [
      {
        "description": "Gain Expertise in two skills of your choice. Sleight of Hand and Stealth are recommended if you have proficiency in them.",
        "level": 1,
        "name": "Expertise",
        "source": "Rogue"
      },
      {
        "description": "Once per turn, deal extra 1d6 damage with Finesse/Ranged weapon if you have Advantage or ally within 5 feet of target. The extra damage's type is the same as the weapon's type.",
        "level": 1,
        "name": "Sneak Attack",
        "source": "Rogue"
      },
      {
        "description": "You know Thieves' Cant and one other language of your choice.",
        "level": 1,
        "name": "Thieves' Cant",
        "source": "Rogue"
      },
      {
        "description": "Use mastery properties of two weapons of your choice with which you have proficiency.",
        "level": 1,
        "name": "Weapon Mastery",
        "source": "Rogue"
      },
      {
        "description": "Your quick thinking and agility allow you to take Dash, Disengage, or Hide as a Bonus Action on your turn.",
        "level": 2,
        "name": "Cunning Action",
        "source": "Rogue"
      },
      {
        "description": "As a Bonus Action, give yourself Advantage on your next attack roll on the current turn. You can use this only if you haven't moved, and your Speed becomes 0 until the end of the turn.",
        "level": 3,
        "name": "Steady Aim",
        "source": "Rogue"
      }
    ],
    "feats": [
      {
        "description": "Always on the lookout for danger, you gain the following benefits:\n\nWhen you roll Initiative, you can add your Proficiency Bonus to the roll.\n\nImmediately after you roll Initiative, you can swap your Initiative with that of one willing ally in the same encounter. You can't make this swap if you or the ally has the Incapacitated condition.",
        "name": "Alert",
        "source": "Criminal"
      }
    ],
    "lineage": [
      {
        "description": "The range of your Darkvision increases to 120 feet.",
        "name": "Extended Darkvision",
        "source": "Drow"
      },
      {
        "description": "You know the Dancing Lights cantrip. You also always have certain spells prepared and can cast them once per day without expending a spell slot. You can also cast them using spell slots you have of the appropriate level.\n\n<table class=\"table table-sm table-bordered mt-2\">\n<thead><tr><th>Character Level</th><th>Spells</th></tr></thead>\n<tbody>\n<tr class=\"table-success\"><td>3</td><td>\u2713 Faerie Fire</td></tr>\n<tr class=\"table-secondary\"><td>5</td><td>\ud83d\udd12 Darkness</td></tr>\n</tbody>\n</table>",
        "level": 5,
        "name": "Drow Spells",
        "source": "Drow"
      }
    ],
    "species": [
      {
        "description": "You have Darkvision with a range of 60 feet.",
        "name": "Darkvision",
        "source": "Elf"
      },
      {
        "description": "You are part of a lineage that grants you supernatural abilities. Intelligence, Wisdom of Charisma is your spellcasting ability for the spells you cast with this trait.",
        "name": "Elven Lineage",
        "source": "Elf"
      },
      {
        "description": "You have Advantage on saving throws you make to avoid or end the Charmed condition.",
        "name": "Fey Ancestry",
        "source": "Elf"
      },
      {
        "description": "You have proficiency in the Insight, Perception, or Survival skill.",
        "name": "Keen Senses: Survival",
        "source": "Elf"
      },
      {
        "description": "You don't need to sleep, and magic can't put you to sleep. You can finish a Long Rest in 4 hours if you spend those hours in a trancelike meditation, during which you retain consciousness.",
        "name": "Trance",
        "source": "Elf"
      }
    ],
    "subclass": [
      {
        "description": "You're adept at ambushing a target. Initiative: You have Advantage on Initiative rolls. Surprising Strikes: During the first round of each combat, you have Advantage on attack rolls against any creature that hasn't taken a turn. If your Sneak Attack hits any target during that round, the target takes extra damage of the weapon's type equal to your Rogue level.",
        "level": 3,
        "name": "Assassinate",
        "source": "Assassin"
      },
      {
        "description": "You gain a Disguise Kit and a Poisoner's Kit, and you have proficiency with them.",
        "level": 3,
        "name": "Assassin's Tools",
        "source": "Assassin"
      }
    ]
  },
