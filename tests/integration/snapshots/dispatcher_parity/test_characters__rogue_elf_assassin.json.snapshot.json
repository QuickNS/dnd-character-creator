  "class_data": {
    "armor_proficiencies": [
      "Light armor"
    ],
    "description": "Rogues rely on cunning, stealth, and their foes' vulnerabilities to get the upper hand. They have a knack for finding solutions to any problem, making precise strikes over brute force. Some began as criminals, others as crime fighters.",
    "features_by_level": {
      "1": {
        "Expertise": {
          "choices": {
            "count": 2,
            "name": "rogue_expertise_skills_1",
            "source": {
              "type": "proficient_skills"
            },
            "type": "select_multiple"
          },
          "description": "Gain Expertise in two skills of your choice. Sleight of Hand and Stealth are recommended if you have proficiency in them.",
          "effects": [
            {
              "from_choice": "rogue_expertise_skills_1",
              "type": "grant_skill_expertise"
            }
          ]
        },
        "Sneak Attack": "Once per turn, deal extra 1d6 damage with Finesse/Ranged weapon if you have Advantage or ally within 5 feet of target. The extra damage's type is the same as the weapon's type.",
        "Thieves' Cant": {
          "choices": {
            "count": 1,
            "name": "thieves_cant_language",
            "source": {
              "file": "languages.json",
              "list": "all",
              "type": "external"
            },
            "type": "select_single"
          },
          "description": "You know Thieves' Cant and one other language of your choice.",
          "effects": [
            {
              "languages": [
                "Thieves' Cant"
              ],
              "type": "grant_language"
            },
            {
              "from_choice": "thieves_cant_language",
              "type": "grant_language"
            }
          ]
        },
        "Weapon Mastery": "Use mastery properties of two weapons of your choice with which you have proficiency."
      },
      "10": {
        "Ability Score Improvement": {
          "choices": {
            "name": "class_feat_10",
            "source": {
              "file": "general_feats.json",
              "list": "general_feats",
              "type": "external"
            }
          },
          "description": "Gain Ability Score Improvement feat or another feat of your choice.",
          "feature_kind": "asi"
        }
      },
      "11": {
        "Improved Cunning Strike": "You can use up to two Cunning Strike effects when you deal Sneak Attack damage, paying the die cost for each effect."
      },
      "12": {
        "Ability Score Improvement": {
          "choices": {
            "name": "class_feat_12",
            "source": {
              "file": "general_feats.json",
              "list": "general_feats",
              "type": "external"
            }
          },
          "description": "Gain Ability Score Improvement feat or another feat of your choice.",
          "feature_kind": "asi"
        }
      },
      "13": {
        "Subclass Feature": {
          "description": "Gain feature from your archetype.",
          "feature_kind": "subclass_feature_slot"
        }
      },
      "14": {
        "Devious Strikes": "New Cunning Strike options: Daze (2d6, Con save or limited to one action/move/bonus on next turn), Knock Out (6d6, Con save or Unconscious 1 min), Obscure (3d6, Dex save or Blinded until end of next turn)."
      },
      "15": {
        "Slippery Mind": {
          "description": "Your mind is exceptionally difficult to control. You gain proficiency in Wisdom and Charisma saving throws.",
          "effects": [
            {
              "abilities": [
                "Wisdom",
                "Charisma"
              ],
              "type": "grant_save_proficiency"
            }
          ]
        }
      },
      "16": {
        "Ability Score Improvement": {
          "choices": {
            "name": "class_feat_16",
            "source": {
              "file": "general_feats.json",
              "list": "general_feats",
              "type": "external"
            }
          },
          "description": "Gain Ability Score Improvement feat or another feat of your choice.",
          "feature_kind": "asi"
        }
      },
      "17": {
        "Subclass Feature": {
          "description": "Gain capstone feature from your archetype.",
          "feature_kind": "subclass_feature_slot"
        }
      },
      "18": {
        "Elusive": "No attack roll can have Advantage against you unless you have the Incapacitated condition."
      },
      "19": {
        "Epic Boon": "Gain an Epic Boon feat or another feat of your choice. Boon of the Night Spirit is recommended."
      },
      "2": {
        "Cunning Action": "Your quick thinking and agility allow you to take Dash, Disengage, or Hide as a Bonus Action on your turn."
      },
      "20": {
        "Stroke of Luck": "If you fail a d20 Test, you can turn the roll into a 20. Once per Short or Long Rest."
      },
      "3": {
        "Rogue Subclass": {
          "description": "Choose your roguish archetype: Arcane Trickster, Assassin, Soulknife, or Thief.",
          "feature_kind": "subclass_pick"
        },
        "Steady Aim": "As a Bonus Action, give yourself Advantage on your next attack roll on the current turn. You can use this only if you haven't moved, and your Speed becomes 0 until the end of the turn."
      },
      "4": {
        "Ability Score Improvement": {
          "choices": {
            "name": "class_feat_4",
            "source": {
              "file": "general_feats.json",
              "list": "general_feats",
              "type": "external"
            }
          },
          "description": "Gain Ability Score Improvement feat or another feat of your choice.",
          "feature_kind": "asi"
        }
      },
      "5": {
        "Cunning Strike": "When you deal Sneak Attack damage, you can add one Cunning Strike effect by foregoing Sneak Attack dice. DC equals 8 + Dexterity modifier + Proficiency Bonus. Options: Poison (1d6, Con save or Poisoned 1 min, requires Poisoner's Kit), Trip (1d6, Dex save or Prone if Large or smaller), Withdraw (1d6, move half speed without provoking).",
        "Uncanny Dodge": "When an attacker you can see hits you with an attack roll, use your Reaction to halve the attack's damage against you."
      },
      "6": {
        "Expertise": {
          "choices": {
            "count": 2,
            "name": "rogue_expertise_skills_6",
            "source": {
              "type": "proficient_skills"
            },
            "type": "select_multiple"
          },
          "description": "Gain Expertise in two more skills of your choice.",
          "effects": [
            {
              "from_choice": "rogue_expertise_skills_6",
              "type": "grant_skill_expertise"
            }
          ]
        }
      },
      "7": {
        "Evasion": "When subjected to a Dexterity saving throw for half damage, you take no damage on a success and half on a failure. You can't use this if you have the Incapacitated condition.",
        "Reliable Talent": "Whenever you make an ability check that uses one of your skill or tool proficiencies, you can treat a d20 roll of 9 or lower as a 10."
      },
      "8": {
        "Ability Score Improvement": {
          "choices": {
