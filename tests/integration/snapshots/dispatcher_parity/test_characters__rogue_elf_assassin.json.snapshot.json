  "subclass": "Assassin",
  "subclass_data": {
    "class": "Rogue",
    "description": "An Assassin's training focuses on using stealth, poison, and disguise to eliminate foes with deadly efficiency. While some are hired killers, spies, or bounty hunters, these capabilities are equally useful for adventurers facing monstrous enemies.",
    "features_by_level": {
      "13": {
        "Envenom Weapons": "When you use the Poison option of your Cunning Strike, the target also takes 2d6 Poison damage whenever it fails the saving throw. This damage ignores Resistance to Poison damage."
      },
      "17": {
        "Death Strike": "When you hit with your Sneak Attack on the first round of a combat, the target must succeed on a Constitution saving throw (DC 8 + your Dexterity modifier + Proficiency Bonus), or the attack's damage is doubled against the target."
      },
      "3": {
        "Assassin's Tools": {
          "description": "You gain a Disguise Kit and a Poisoner's Kit, and you have proficiency with them.",
          "effects": [
            {
              "tools": [
                "Disguise Kit",
                "Poisoner's Kit"
              ],
              "type": "grant_tool_proficiency"
            }
          ]
        },
        "Assassinate": "You're adept at ambushing a target. Initiative: You have Advantage on Initiative rolls. Surprising Strikes: During the first round of each combat, you have Advantage on attack rolls against any creature that hasn't taken a turn. If your Sneak Attack hits any target during that round, the target takes extra damage of the weapon's type equal to your Rogue level."
      },
      "9": {
        "Infiltration Expertise": "Masterful Mimicry: You can unerringly mimic another person's speech, handwriting, or both if you have spent at least 1 hour studying them. Roving Aim: Your Speed isn't reduced to 0 by using Steady Aim."
      }
    },
    "name": "Assassin",
    "source": "Player's Handbook 2024"
  },
