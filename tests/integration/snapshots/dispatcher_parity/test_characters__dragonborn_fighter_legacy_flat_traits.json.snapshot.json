    "species": [
      {
        "description": "Your lineage stems from a dragon progenitor. Choose the kind of dragon from the list. Your choice affects your Breath Weapon and Damage Resistance traits as well as your appearance.",
        "name": "Draconic Ancestry: Red (Fire)",
        "source": "Dragonborn"
      },
      {
        "choice_substitutions": {
          "damage_type": "Draconic Ancestry"
        },
        "description": "When you take the Attack action on your turn, you can replace one of your attacks with an exhalation of Fire energy in either a 15-foot Cone or a 30-foot Line that is 5 feet wide. Each creature in that area must make a Dexterity saving throw (DC 8 + your Constitution modifier + Proficiency Bonus). On a failed save, a creature takes 1d10 Fire damage. On a successful save, a creature takes half as much damage. This damage increases by 1d10 when you reach character levels 5 (2d10), 11 (3d10), and 17 (4d10). You can use this Breath Weapon a number of times equal to your Proficiency Bonus, and you regain all expended uses when you finish a Long Rest.",
        "name": "Breath Weapon",
        "source": "Dragonborn"
      },
      {
        "choice_substitutions": {
          "damage_type": "Draconic Ancestry"
        },
        "description": "You have Resistance to Fire damage.",
        "name": "Damage Resistance",
        "source": "Dragonborn"
      },
      {
        "description": "You have Darkvision with a range of 60 feet.",
        "name": "Darkvision",
        "source": "Dragonborn"
      },
      {
        "description": "When you reach character level 5, you can channel draconic magic to give yourself temporary flight. As a Bonus Action, you sprout spectral wings on your back that last for 10 minutes or until you retract the wings (no action required) or have the Incapacitated condition. During that time, you have a Fly Speed equal to your Speed. Your wings appear to be made of the same energy as your Breath Weapon. Once you use this trait, you can't use it again until you finish a Long Rest.",
        "name": "Draconic Flight",
        "source": "Dragonborn"
      }
    ],
